{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/check-acp.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "write_file",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/format-on-write.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/review-on-complete.sh"
					}
				]
			}
		]
	}
}
